{
  "name": "chatbot-app",
  "version": "1.0.0",
  "description": "Local LLM chatbot with adversarial guardrails, multi-turn history, and Markdown rendering",
  "main": "server.js",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "keywords": [
    "chatbot",
    "llm",
    "local-llm",
    "promptfoo",
    "guardrails",
    "ai-security",
    "lm-studio"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test guardrails.test.js",
    "check": "node scripts/check.js",
    "eval": "npx promptfoo@latest eval",
    "eval:view": "npx promptfoo@latest view"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Antak108/chatbot-app.git"
  },
  "homepage": "https://github.com/Antak108/chatbot-app",
  "bugs": {
    "url": "https://github.com/Antak108/chatbot-app/issues"
  }
}
